<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Expense Tracker - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #f5f5f5; padding-top: 50px; font-family: sans-serif;">

    <div class="card shadow-sm p-4 mx-auto" style="max-width: 850px; background-color: #ffffff; border: none; border-radius: 4px;">
        
        <h2 class="text-center fw-bold mb-3" style="color: #212529;">Welcome to Expense Tracker</h2>
        
        <div class="d-flex justify-content-center gap-4 mb-4">
            <a href="/addExpense" style="color: #4caf50; text-decoration: none; font-weight: 500;">Add Expense</a>
            <a href="/" style="color: #4caf50; text-decoration: none; font-weight: 500;">Expense List</a>
        </div>
        
        <p class="text-muted small text-center mb-4">
            Track and manage your expenses effectively. Use the navigation links to add new expenses or view your expense history.
        </p>

        <hr style="border-color: #eee;" />

        <div class="mt-3">
            <h4 class="fw-bold mb-3" style="color: #212529;">Expense History</h4>
            
            <div th:if="${#lists.isEmpty(expenses)}" class="alert alert-light text-center text-muted">
                No expenses tracked yet. Click "Add Expense" to start!
            </div>

            <div th:each="exp : ${expenses}" class="border-bottom py-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 th:text="${exp.expenseName}" style="color: #4caf50; font-weight: 600; margin-bottom: 4px;">Lunch</h5>
                        <p class="mb-1 text-secondary small"><strong>Amount:</strong> $<span th:text="${exp.amount}">0.00</span></p>
                        <p class="mb-1 text-secondary small"><strong>Date:</strong> <span th:text="${exp.date}">2026-07-03</span></p>
                        <p class="text-muted small mb-0" th:text="${exp.description}">Details...</p>
                    </div>
                    <div>
                        <a th:href="@{/editExpense/{id}(id=${exp.id})}" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </div>
                </div>
            </div>
        </div>

    </div>

</body>
</html>