<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Update Expense</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #f5f5f5; padding-top: 50px;">

    <div class="card shadow-sm p-4 mx-auto" style="max-width: 600px; background-color: #ffffff; border: none;">
        <h3 class="fw-bold mb-4">Update Expense</h3>
        
        <form th:action="@{/updateExpense/{id}(id=${expense.id})}" th:object="${expense}" method="POST">
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Expense Name:</label>
                <input type="text" th:field="*{expenseName}" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Amount ($):</label>
                <input type="number" step="0.01" th:field="*{amount}" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Date:</label>
                <input type="date" th:field="*{date}" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Description:</label>
                <textarea th:field="*{description}" class="form-control" rows="3"></textarea>
            </div>
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Update Expense</button>
                <a th:href="@{/}" class="btn btn-light px-4">Cancel</a>
            </div>
        </form>
    </div>

</body>
</html>